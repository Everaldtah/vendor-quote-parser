# Server
PORT=8000
DEBUG=false

# Optional: OpenAI for AI-enhanced parsing (improves accuracy on messy PDFs)
OPENAI_API_KEY=sk-...

# Optional: Database URL (defaults to in-memory store)
DATABASE_URL=sqlite:///./quotes.db

# Optional: Email notifications for quote alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=yourpassword
NOTIFY_EMAIL=team@yourcompany.com

# Optional: Webhook for Slack/Teams alerts
WEBHOOK_URL=https://hooks.slack.com/services/...
